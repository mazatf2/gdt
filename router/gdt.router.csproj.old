<Project Sdk="Godot.NET.Sdk/4.6.1">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net10.0</TargetFramework>
		<EnableDynamicLoading>true</EnableDynamicLoading>
	</PropertyGroup>
	<ItemGroup>
		<Content Include="package.json"/>
		<Content Include="src\pages\main\main.tscn"/>
	</ItemGroup>
	<ItemGroup>
		<Folder Include=".export\" />
		<Folder Include=".godot\"/>
		<Folder Include="src\pages\main\montly_report\" />
	</ItemGroup>
	<PropertyGroup>
		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
	</PropertyGroup>
</Project>
